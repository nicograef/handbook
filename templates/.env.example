# .env.example — standard environment variables for Docker Compose templates
# Copy to .env and fill in real values. Never commit .env to version control.
#
# Used by: docker-compose.yml, docker-compose.prod.yml, Makefile

# ── Database ──
POSTGRES_USER=admin
POSTGRES_PASSWORD=<your-db-password>
POSTGRES_DB=<your-database-name>

# ── Application ──
# APP_PORT=8080
# APP_ENV=production

# ── Domain (production only) ──
# DOMAIN=<your-domain.com>
# CERTBOT_EMAIL=<your-email@example.com>

# ── Secrets ──
# JWT_SECRET=<your-jwt-secret>
